# App Store screenshot matrix (en-US). Refresh device names after Xcode updates:
#   xcrun simctl list devices available | grep -E 'iPhone|iPad Pro'

scheme("Farkle Score. Screenshots")

project("Farkle Score..xcodeproj")

devices([
  "iPhone 17 Pro Max",
  "iPad Pro 13-inch (M5)",
  "iPad Pro 11-inch (M5)",
  "Mac"
])

languages([
  "en-US"
])

launch_arguments([
  "-screenshotMode"
])

output_directory("./screenshots")

clear_previous_screenshots(true)

skip_open_summary(true)

# Single appearance for v1 (no light/dark matrix).
dark_mode(false)
